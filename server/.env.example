PORT=3090
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=shortlink_db

# 可选：强制指定前端基本 URL 以重定向状态页面
# 如果为空，服务器将根据请求来源/引用页推断 URL
FRONTEND_BASE_URL=

# 生成的短链接中使用的公共基础 URL，例如 https://s.example.com
# 如果为空，服务器将回退到当前请求主机
SHORTLINK_BASE_URL=

# 允许多个 CORS 来源（以逗号分隔），支持通配符，例如 https://*.example.com
# 留空则允许所有来源
CORS_ALLOWED_ORIGINS=https://a.example.com,https://b.example.com

# 前端身份验证，防止滥用
# 受保护的 API：GET /api/pan-search、POST /api/short-links、POST /api/ai/mindmap/stream
FRONTEND_AUTH_ENABLED=true
FRONTEND_AUTH_SECRET=change_this_to_a_long_random_secret
FRONTEND_AUTH_CHALLENGE_TTL_SEC=90
FRONTEND_AUTH_CLOCK_SKEW_SEC=15
FRONTEND_AUTH_BIND_ORIGIN=true

# 盘搜 API
PAN_SEARCH_API_URL=https://example.com/search
PAN_SEARCH_API_TOKEN=
PAN_SEARCH_TIMEOUT_MS=12000

# AI 思维导图（OpenAI 兼容）
# 只填域名也可以，例如：https://abc.com 或 https://abc.com/
# 后端会自动补全为 /v1/chat/completions
AI_API_BASE_URL=https://api.openai.com
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=60000
